# 카페24 API 설정
CAFE24_MALL_ID=your_mall_id
CAFE24_CLIENT_ID=your_client_id
CAFE24_CLIENT_SECRET=your_client_secret
CAFE24_REDIRECT_URI=http://localhost:5000/oauth/callback

# 인스타몬스터 API 설정
INSTAMONSTER_API_KEY=your_api_key
INSTAMONSTER_API_URL=https://instamonster.co.kr/api/v2

# Flask 설정
FLASK_SECRET_KEY=change-this-to-random-secret-key
FLASK_DEBUG=true

# 폴링 설정 (초)
POLLING_INTERVAL=90
